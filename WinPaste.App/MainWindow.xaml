<Window x:Class="WinPaste.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinPaste"
        Width="1040"
        Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_OnDeactivated"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              Direction="270"
                              Opacity="0.23"
                              ShadowDepth="6"
                              Color="{DynamicResource PanelShadowColor}" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,12">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding CountLabel}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Text="WinPaste"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>

            <Grid Grid.Row="1">
                <TextBlock x:Name="EmptyState"
                           Text="Historia schowka jest pusta"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <ListBox x:Name="ClipList"
                         ItemsSource="{Binding Clips}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionMode="Single"
                         MouseDoubleClick="ClipList_OnMouseDoubleClick"
                         PreviewMouseLeftButtonUp="ClipList_OnPreviewMouseLeftButtonUp">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Margin" Value="0,0,12,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <Border x:Name="SelectionFrame"
                                                BorderBrush="Transparent"
                                                BorderThickness="2"
                                                CornerRadius="8"
                                                Padding="2">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SelectionFrame" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SelectionFrame" Property="BorderBrush" Value="{DynamicResource HoverBorderBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210"
                                    Height="192"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="132" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="{DynamicResource PreviewBackgroundBrush}"
                                            CornerRadius="6"
                                            ClipToBounds="True">
                                        <Grid>
                                            <TextBlock x:Name="TextPreview"
                                                       Text="{Binding DisplayText}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="13"
                                                       LineHeight="18"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Padding="10" />
                                            <Image x:Name="ImagePreview"
                                                   Source="{Binding ImageUri}"
                                                   Stretch="UniformToFill"
                                                   Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <DockPanel Grid.Row="1"
                                               LastChildFill="False"
                                               Margin="0,10,0,0">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding KindLabel}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding TimeLabel}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" />
                                    </DockPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                    <Setter TargetName="TextPreview" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="ImagePreview" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
